# AEGENTIX CYBERNETICS — Environment Configuration
# Copy this file to .env and fill in your values

# WorldMonitor
WORLDMONITOR_URL=http://worldmonitor:8080

# AEGENTIS VR Backend
SOVEREIGN_JWT_SECRET=change-me-in-production-use-64-random-bytes
VR_WS_TOKEN=

# Jarvis Orchestrator
JARVIS_ENTITY_ID=jarvis-prime
JARVIS_LOOP_INTERVAL=5.0
OPENAI_API_KEY=

# RuView Physical Telemetry
RUVIEW_URL=http://ruview:9090
RUVIEW_POLL_MS=2000

# Orbital Observer
OBSERVER_PORT=9000
